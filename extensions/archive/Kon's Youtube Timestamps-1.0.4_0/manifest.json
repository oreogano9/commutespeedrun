{
   "action": {
      "default_popup": "popup/popup.html"
   },
   "background": {
      "service_worker": "background/background.js",
      "type": "module"
   },
   "content_scripts": [ {
      "all_frames": true,
      "css": [ "content/content.css" ],
      "js": [ "content/content.js" ],
      "matches": [ "https://*.youtube.com/*" ],
      "run_at": "document_start"
   } ],
   "declarative_net_request": {
      "rule_resources": [ {
         "enabled": true,
         "id": "ruleset_1",
         "path": "rules.json"
      } ]
   },
   "description": "Sync YouTube comments with video playback and highly customizable timestamp overlays.",
   "host_permissions": [ "https://*.youtube.com/" ],
   "icons": {
      "128": "icons/128x128.png",
      "16": "icons/16x16.png",
      "48": "icons/48x48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Timestamp Chatter",
   "permissions": [ "storage", "declarativeNetRequestWithHostAccess", "tabs" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0.4",
   "web_accessible_resources": [ {
      "matches": [ "https://*.youtube.com/*" ],
      "resources": [ "images/eye-open.png", "images/eye-closed.png", "images/eye-open.svg", "images/eye-closed.svg" ]
   } ]
}
